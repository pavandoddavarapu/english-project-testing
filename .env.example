# Environment Variables for Local Development
# Copy this file to .env.local and fill in your keys
# .env.local is gitignored and never committed

# ── PostgreSQL Database ──────────────────────────────────────
# Supabase, Neon, or any PostgreSQL connection string
# Vercel auto-sets POSTGRES_URL if you use Vercel Postgres
DATABASE_URL=postgresql://user:password@host:port/database

# ── Unsplash (for Picture Talk images) ──────────────────────
# Get free key at https://unsplash.com/developers → Create app
# Free tier: 50 requests/hour (plenty with our caching)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# ── Pexels (fallback for Picture Talk images) ────────────────
# Get free key at https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# ── Gemini AI (for daily topics + chat) ──────────────────────
# Get free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Groq AI (for speech analysis + fallback) ─────────────────
# Get free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Resend (for email streak reminders) ──────────────────────
# Get free key at https://resend.com → Create API key
# Free tier: 3000 emails/month — more than enough
RESEND_API_KEY=your_resend_api_key_here

# ── Web Push / VAPID (for push notifications) ─────────────────
# Generate keys by running: npx web-push generate-vapid-keys
# VAPID_SUBJECT should be your email or URL (e.g., mailto:you@example.com)
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:your_email@example.com

# ── Security & Infrastructure ────────────────────────────────
# Secret token to authenticate process-queue background calls
WORKER_SECRET=a_long_random_string_here

# CORS: Comma-separated list of allowed origins (production domains)
# e.g., https://english-project-testing.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500
